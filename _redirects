# Netlify / Cloudflare Pages: www → domínio canónico (sem www)
# https://docs.netlify.com/routing/redirects/
https://www.csv-materiaisdelimpeza.com.br/*  https://csv-materiaisdelimpeza.com.br/:splat  301!

# Home: canonical = "/". Forçar 301 para o ficheiro index.html não ficar em 200 paralelo a "/".
/index.html  /  301!

# Índice do blog: URL canónica = /blog.html (sitemap + canonical).
# 301! = forçar: caso contrário o Netlify serve 200 em /blog via Pretty URL e duplica o relatório no GSC.
/blog  /blog.html  301!
/blog/  /blog.html  301!

# Post: /blog/<data>/index.html → /blog/<data>/ (igual ao canonical). 301! para ganhar ao ficheiro estático index.html.
/blog/:slug/index.html  /blog/:slug/  301!
