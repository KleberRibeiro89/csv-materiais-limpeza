# Apache: HTTPS + domínio canónico sem www (301 único quando possível)
# Colocar na raiz do site publicado. Requer mod_rewrite.
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{HTTPS} off [OR]
  RewriteCond %{HTTP_HOST} ^www\.csv-materiaisdelimpeza\.com\.br$ [NC]
  RewriteRule ^ https://csv-materiaisdelimpeza.com.br%{REQUEST_URI} [L,R=301]
</IfModule>
