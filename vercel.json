{
  "trailingSlash": true,
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.csv-materiaisdelimpeza.com.br" }],
      "destination": "https://csv-materiaisdelimpeza.com.br/:path*",
      "permanent": true
    },
    {
      "source": "/index.html",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/blog",
      "destination": "/blog.html",
      "permanent": true
    },
    {
      "source": "/blog/",
      "destination": "/blog.html",
      "permanent": true
    },
    {
      "source": "/blog/:slug/index.html",
      "destination": "/blog/:slug/",
      "permanent": true
    }
  ]
}
